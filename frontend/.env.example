# ===========================================
# Chattix Frontend — Environment Variables
# ===========================================
# Copy this file to .env and fill in real values.
# Variables must be prefixed with VITE_ to be accessible in the app.

# API Endpoints
VITE_API_URL=http://localhost:5000/api
VITE_SOCKET_URL=http://localhost:5000

# Mobile/Network API URL (used when accessing from non-localhost)
VITE_MOBILE_API_URL=http://192.168.1.26:5000/api

# Giphy
VITE_GIPHY_API_KEY=your_giphy_api_key

# LocationIQ
VITE_LOCATIONIQ_ACCESS_TOKEN=your_locationiq_token
